{
  "schemaVersion": 1,
  "id": "skillhub-skill-video-summarize",
  "slug": "video-summarize",
  "name": "Video Summarize",
  "version": "1.0.7",
  "description": "Summarize video from YouTube, direct URL, upload, or local file path via SkillHub.",
  "summary": "Transcript-first YouTube summarization with Gemini native video fallback for direct and local files.",
  "compatibility": {
    "claws": [
      "goclaw"
    ]
  },
  "inputs": [
    "youtube_url",
    "url",
    "upload",
    "file_path"
  ],
  "defaultRuntimeConfig": {
    "skillHubUrl": "http://skillhub:4080",
    "defaultModel": "gemini-3.1-flash-lite-preview",
    "youtubeMode": "auto",
    "supportedFormats": [
      "mp4",
      "mkv",
      "webm",
      "mov",
      "avi"
    ],
    "maxFileSizeBytes": 2147483648
  },
  "defaultProvider": {
    "type": "gemini_native",
    "slug": "gemini-video",
    "displayName": "Gemini Native",
    "defaultModel": "gemini-3.1-flash-lite-preview"
  },
  "package": {
    "type": "zip",
    "path": "skills/video-summarize/video-summarize.zip",
    "installPathTemplate": "/app/data/skills-store/video-summarize/1/"
  },
  "docs": {
    "skill": "skills/video-summarize/SKILL.md",
    "usage": "skills/video-summarize/references/usage.md",
    "resultFormat": "skills/video-summarize/references/result-format.md"
  }
}
